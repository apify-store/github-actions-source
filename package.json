{
    "name": "crawlee-cheerio-typescript",
    "version": "0.0.1",
    "type": "module",
    "description": "This is a boilerplate of an Apify actor.",
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "@apify/consts": "^2.26.0",
        "apify": "^3.1.10",
        "apify-client": "^2.9.3"
    },
    "devDependencies": {
        "@apify/eslint-config-ts": "^0.3.0",
        "@apify/tsconfig": "^0.1.0",
        "@typescript-eslint/eslint-plugin": "^6.7.2",
        "@typescript-eslint/parser": "^6.7.2",
        "eslint": "^8.50.0",
        "tsx": "^4.19.2",
        "typescript": "^5.7",
        "vitest": "^2.1.5"
    },
    "scripts": {
        "start": "npm run start:dev",
        "gha:start:build": "node dist/main.js",
        "start:dev": "GITHUB_WORKSPACE=local-clone tsx src/main.ts",
        "start:runner": "node dist/runner.js",
        "build": "tsc",
        "lint": "eslint ./src --ext .ts",
        "lint:fix": "eslint ./src --ext .ts --fix",
        "test": "vitest run"
    },
    "author": "It's not you it's me",
    "license": "ISC"
}
